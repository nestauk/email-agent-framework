# Database
DATABASE_URL=postgresql://email_user:email_password@localhost:5432/email_agent
POSTGRES_USER=email_user
POSTGRES_PASSWORD=email_password
POSTGRES_DB=email_agent

# LLM Provider (Azure OpenAI)
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT_MINI=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-5-mini
AZURE_OPENAI_ENDPOINT_NANO=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NANO=gpt-5-nano

# Gmail OAuth (for Gmail integration)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
# GMAIL_TOKEN={"token": "...", "refresh_token": "...", ...}

# Agent API authentication
AGENT_API_KEY=dev-agent-api-key

# Worker settings
WORKER_GMAIL_POLL_SECONDS=30
WORKER_GMAIL_LOOKBACK_MINUTES=120
WORKER_AUTO_ACCEPT_INTERRUPTS=false

# RAG settings (set to false to disable Qdrant vector store)
INCLUDE_RAG=true

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=
LANGSMITH_ORG_ID=
LANGSMITH_PROJECT_ID=

# Logging
LOGLEVEL=INFO
LOG_QUIET=false
